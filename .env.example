# ==============================================================================
# Civio Environment Variables Example Config
# Rename this file to .env and configure the variables accordingly.
# ==============================================================================

# Starlette session encryption key (used for authentication cookies in templates)
SECRET_KEY=civio-dev-secret-key-2026

# Server Port
PORT=5000

# ------------------------------------------------------------------------------
# 1. Map Configuration
# ------------------------------------------------------------------------------
# MapTiler Key for modern raster/vector maps.
# If left empty, Civio falls back to CartoDB Voyager tiles (no key required).
MAPTILER_KEY=
MAPTILER_STYLE=hybrid

# ------------------------------------------------------------------------------
# 2. AI Engines & Core Services
# ------------------------------------------------------------------------------
# Gemini API Key (Required for AI issue triage, spam checking, and resolution console)
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 3. Databases (PostgreSQL / Firebase / SQLite)
# ------------------------------------------------------------------------------
# PostgreSQL Connection URL (e.g. postgres://user:pass@host:port/db)
# If provided, Civio connects to Postgres. Otherwise, falls back to Firestore/SQLite.
DATABASE_URL=

# Firebase Configuration (Alternative Cloud database fallback)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------------------------
# 4. Notification Services
# ------------------------------------------------------------------------------
# Resend API Key for official dispatch emails
RESEND_API_KEY=
RESEND_FROM=Civio <onboarding@resend.dev>
DEMO_RECIPIENT_EMAIL=

# Twilio Credentials for official WhatsApp notification alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_SANDBOX_CODE=join feet-cheese
WA_NOTIFY_DRY_RUN=1
